# JWT Configuration
JWT_SECRET=your-secret-key-here

# Stripe API Keys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_SUBSCRIPTION_PRICE_ID=price_XXXXXXXXXXXXXX

# Server Port
PORT=8080

# Google OAuth (optional for development)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend.vercel.app/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://your-backend.vercel.app/auth/github/callback

# Session Secret
SESSION_SECRET=your-session-secret-here

# Frontend host for OAuth/Stripe redirects
FRONTEND_URL=https://your-netlify-site.netlify.app

# Database URL (for production - Vercel / Neon)
# Use a PostgreSQL connection string, not the Neon dashboard auth page URL.
DATABASE_URL=postgresql://user:password@ep-calm-block-ami8d61q.neonauth.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require
# Or use NEON_DATABASE_URL if you prefer a Neon-specific variable.
NEON_DATABASE_URL=postgresql://user:password@ep-calm-block-ami8d61q.neonauth.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# Node Environment
NODE_ENV=development
