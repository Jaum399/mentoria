# Produção - Backend no Vercel com banco Neon/Postgres

# Conexão com o banco de dados (Neon / Postgres)
# Use o valor correto fornecido pelo painel Neon ou Vercel.
DATABASE_URL=postgresql://USER:PASSWORD@ep-calm-block-ami8d61q.neonauth.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require
# Caso queira separar o nome, também é aceito:
NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-calm-block-ami8d61q.neonauth.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# Host do frontend para redirecionos OAuth/Stripe
FRONTEND_URL=https://<seu-frontend>.netlify.app

# JWT e sessão
JWT_SECRET=uma-chave-secreta-muito-forte-e-unica
SESSION_SECRET=outra-chave-secreta-e-forte

# Stripe
STRIPE_SECRET_KEY=sk_live_seu_token_secreto
STRIPE_PUBLISHABLE_KEY=pk_live_seu_token_publicavel
STRIPE_WEBHOOK_SECRET=whsec_seu_segredo_de_webhook
STRIPE_SUBSCRIPTION_PRICE_ID=price_XXXXXXXXXXXXXXXX

# Google OAuth
GOOGLE_CLIENT_ID=seu-google-client-id
GOOGLE_CLIENT_SECRET=seu-google-client-secret
GOOGLE_CALLBACK_URL=https://<seu-backend>.vercel.app/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=seu-github-client-id
GITHUB_CLIENT_SECRET=seu-github-client-secret
GITHUB_CALLBACK_URL=https://<seu-backend>.vercel.app/auth/github/callback

# Ambiente
NODE_ENV=production
